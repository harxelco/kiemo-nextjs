# ============================================================
# KIEMO MENS WEAR — Environment Variables
# Copy this file to .env.local for local dev, and enter the same
# values in Vercel → Project → Settings → Environment Variables
# for Preview + Production.
# ============================================================

# ---- PHASE 1 & 2 (Supabase — checkout, reviews, admin auth) ----
# From Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key — SERVER ONLY. Never prefix with NEXT_PUBLIC_,
# never commit it, never send it to the browser. Used only inside
# app/api/orders/route.ts to insert orders past RLS.
SUPABASE_SERVICE_ROLE_KEY=

# Public site URL — used for metadata/canonical tags and CORS-safety checks.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---- PHASE 3 (M-Pesa Daraja) — not required yet, wired in Manual 02 ----
# DARAJA_CONSUMER_KEY=
# DARAJA_CONSUMER_SECRET=
# DARAJA_SHORTCODE=
# DARAJA_TILL_NUMBER=
# DARAJA_PASSKEY=
# DARAJA_ENV=sandbox
# DARAJA_CALLBACK_URL=

# ---- PHASE 5 (SEO / Monitoring) — not required yet ----
# NEXT_PUBLIC_GA_MEASUREMENT_ID=
# NEXT_PUBLIC_SENTRY_DSN=
